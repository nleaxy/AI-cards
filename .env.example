# Flask Backend Configuration
SECRET_KEY=your-super-secret-flask-key
JWT_SECRET_KEY=your-super-secret-jwt-key
API_KEY=your-gemini-or-openrouter-key

# PostgreSQL Database Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin_password
POSTGRES_DB=study_cards
# SQLALCHEMY_DATABASE_URI is built dynamically or provided explicitly:
SQLALCHEMY_DATABASE_URI=postgresql://admin:admin_password@db:5432/study_cards

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=uploads
